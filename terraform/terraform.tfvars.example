project_name = "takehome-webapp"
aws_region   = "us-east-2"

# Use an absolute path.
# First run from the project root: ./scripts/generate-ssh-key.sh
# Relative paths are resolved from terraform/
ssh_public_key_path = "../out/kubeadm-gateway_ed25519.pub"

# For more secure setup Replace with your current public IP, e.g. curl -4 ifconfig.me
# I'm intentionally setting this open to the internet for this demo. This is still
# protected by ssh keys.
allowed_ssh_cidr = "0.0.0.0/0"

# Just like the ssh key above this can be used to restrict who has access to the  
# kubernetes-api mTLS and client certs protect us here so we can make this endpoint
# public unless security requires the change.
allowed_kube_api_cidr = "0.0.0.0/0"


# Public demo access for the NLB path. Tighten this if you only need reviewer IPs.
allowed_web_cidr_blocks = ["0.0.0.0/0"]

instance_type       = "t3.medium"
worker_count        = 2
root_volume_size_gb = 30
